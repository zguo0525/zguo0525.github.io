source "https://rubygems.org"

# Use the github-pages gem so local builds match GitHub Pages' versions of
# Jekyll and supported plugins.
gem "github-pages", group: :jekyll_plugins

# Required on Ruby 3.0+ where webrick is no longer bundled.
gem "webrick", "~> 1.8"

# Stdlib gems removed in Ruby 3.4 / 4.0 that Jekyll 3.9 still needs.
gem "csv"
gem "logger"
gem "ostruct"
gem "base64"
gem "bigdecimal"
gem "mutex_m"
